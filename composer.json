{
  "name": "lunr/cliparser",
  "description": "Lunr.CliParser is a library for parsing command line arguments.",
  "keywords": [ "cli", "getopt" ],
  "homepage": "https://github.com/lunr-php/lunr.cliparser",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "lunr/halo": "dev-master",
    "phpunit/phpunit": ">=10.5 <11.0",
    "ext-xdebug": "~3.1"
  },
  "config": {
    "audit": {
      "ignore": [
        "PKSA-z3gr-8qht-p93v"
      ]
    },
    "optimize-autoloader": true
  },
  "autoload": {
    "psr-4": {"Lunr\\": "src/Lunr/"}
  }
}
